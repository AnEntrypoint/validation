{
  "name": "@sequentialos/validation",
  "version": "1.0.0",
  "description": "Consolidated validation engine combining schema validation, param validation, type checking, and error formatting",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./ajv": "./src/ajv-instance.js",
    "./schema": "./src/schema-compiler.js",
    "./field": "./src/field-validators.js",
    "./type": "./src/type-validators.js",
    "./result": "./src/validation-result.js",
    "./error": "./src/error-formatter.js",
    "./chain": "./src/validation-chain.js",
    "./middleware": "./src/middleware.js"
  },
  "keywords": [
    "validation",
    "schema",
    "json-schema",
    "type-checking",
    "error-formatting",
    "param-validation"
  ],
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "@sequentialos/path-validation": "file:../path-validation"
  }
}
